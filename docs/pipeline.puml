@startuml pipeline
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam ArrowColor #555555
skinparam ArrowThickness 1.5
skinparam roundCorner 8

skinparam activity {
  BackgroundColor #F8F9FA
  BorderColor #DEE2E6
  FontColor #212529
  DiamondBackgroundColor #FFF3CD
  DiamondBorderColor #FFCA2C
}

title Trading Pipeline — Lookahead Bias Prevention

|#E3F2FD| Data Layer |
start
:Sync from TWSE / FinMind / yfinance;
note right
  OHLCV, PER/PBR,
  institutional trades,
  margin, monthly revenue
end note
:Store in SQLite (WAL);

|#F1F8E9| Feature Layer |
:QlibExporter → .bin files;
:Compute ~300 factors
(Alpha158 + Taiwan chips
+ interaction + enhanced);

|#FFF3E0| Training Layer |
:Walk-Forward window
(504d train / 100d valid / 7d embargo);
:DoubleEnsemble training
(K=3 LightGBM sub-models
+ sample reweighting
+ feature selection);
:Save model to data/models/;

|#F3E5F5| Prediction Layer |
:Load T-1 features
(strict: no T-day data);
:Cross-sectional ranking
of top-100 stocks;
:Generate Top-K signals;

|#E8F5E9| Evaluation Layer |
:Multi-strategy backtesting
(TopK / TopKDrop / HoldDrop);
:IC analysis
(multi-horizon, rolling, regime);
:Report metrics
(Sharpe, MaxDD, excess, t-stat);
stop

@enduml
